# ==========================================
# THPT Edison — Environment Configuration
# ==========================================
# Copy file này thành .env và điền giá trị thật
# TUYỆT ĐỐI KHÔNG COMMIT file .env chứa secret lên Git!

# Database — Tạo user riêng, KHÔNG dùng root
DATABASE_URL="mysql://thpt_edison_app:YOUR_STRONG_PASSWORD@localhost:3306/thpt_edison"

# JWT — Generate secret mạnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_BYTE_HEX_STRING"

# App
NEXT_PUBLIC_APP_NAME="Trường THPT Edison"
NEXT_PUBLIC_APP_URL="https://your-domain.edu.vn"

# Upload limits (bytes)
MAX_IMAGE_SIZE=5242880
MAX_DOCUMENT_SIZE=20971520

# AI Services (optional)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"
